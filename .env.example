# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=your_db_url
# Optional: timezone used for all date formatting and dashboard datetime inputs.
# Fallback: America/New_York when empty or invalid.
NEXT_PUBLIC_APP_TIMEZONE=America/New_York
# Optional: social links shown on the home page. Leave empty to disable clicking.
NEXT_PUBLIC_SOCIAL_BILIBILI_URL=https://space.bilibili.com/
NEXT_PUBLIC_SOCIAL_GITHUB_URL=https://github.com/
NEXT_PUBLIC_SOCIAL_EMAIL_URL=mailto:your@email.com
NEXT_PUBLIC_SOCIAL_QQ_URL=
# Webhook Configuration
SITE_URL=your_webhook_secret
WEBHOOK_SECRET=your_webhook_secret
