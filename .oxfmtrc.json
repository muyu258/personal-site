{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "ignorePatterns": ["**/*-lock.json", "bun.lock", "src/types/supabase.ts"],
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": {
    "internalPattern": ["#"]
  },
  "sortPackageJson": false,
  "sortTailwindcss": {
    "stylesheet": "./src/styles/tailwind.css",
    "functions": ["clsx", "cn"],
    "preserveWhitespace": true
  }
}
