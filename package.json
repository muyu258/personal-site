{
  "name": "bblf-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check . && tsc --noEmit",
    "format": "biome check --write --unsafe .",
    "menu": "bun ./scripts/menu.ts",
    "gen:types:dev": "source .env.development && bunx supabase gen types typescript --project-id $(echo $NEXT_PUBLIC_SUPABASE_URL | sed 's/https:\\/\\///' | cut -d'.' -f1) > src/types/supabase.ts",
    "gen:types:prod": "source .env.production && bunx supabase gen types typescript --project-id $(echo $NEXT_PUBLIC_SUPABASE_URL | sed 's/https:\\/\\///' | cut -d'.' -f1) > src/types/supabase.ts",
    "gen:icons": "svgr --out-dir src/components/icons --typescript --icon --replace-attr-values \"#000=currentColor\" public/svg-icons"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.5",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "@tailwindcss/typography": "^0.5.19",
    "@uiw/react-codemirror": "^4.25.9",
    "@vercel/speed-insights": "^2.0.0",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "fflate": "^0.8.2",
    "framer-motion": "^12.26.2",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.562.0",
    "next": "16.1.3",
    "prism-themes": "^1.9.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-prism-plus": "^2.0.2",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.97.3",
    "sonner": "^2.0.7",
    "supabase": "^2.72.8",
    "tailwind-merge": "^3.4.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "postcss-scss": "^4.0.9",
    "postgres": "^3.4.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
